{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://memo-agent.local/schemas/rubric.schema.json",
  "title": "Memo Agent Rubric",
  "description": "Defines what gets scored in an investment memo, on what scale, by whom (machine vs partner), and what evidence supports each score.",
  "type": "object",
  "required": ["scoring_scale", "confidence_levels", "scoring_modes", "dimensions"],
  "additionalProperties": false,
  "properties": {
    "meta": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "version": { "type": "string" },
        "last_updated": { "type": "string" },
        "owner": { "type": "string" },
        "notes": { "type": "string" }
      }
    },
    "scoring_scale": {
      "type": "object",
      "required": ["type", "range", "levels"],
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "enum": ["integer"] },
        "range": {
          "type": "array",
          "items": { "type": "integer" },
          "minItems": 2,
          "maxItems": 2
        },
        "levels": {
          "type": "object",
          "patternProperties": {
            "^[0-9]+$": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": false,
          "minProperties": 2
        }
      }
    },
    "confidence_levels": {
      "type": "array",
      "items": { "type": "string", "enum": ["low", "medium", "high"] },
      "minItems": 1,
      "uniqueItems": true
    },
    "scoring_modes": {
      "type": "object",
      "required": ["machine", "partner_only", "hybrid"],
      "additionalProperties": false,
      "properties": {
        "machine": {
          "type": "object",
          "required": ["description"],
          "properties": { "description": { "type": "string" } }
        },
        "partner_only": {
          "type": "object",
          "required": ["description"],
          "properties": { "description": { "type": "string" } }
        },
        "hybrid": {
          "type": "object",
          "required": ["description"],
          "properties": { "description": { "type": "string" } }
        }
      }
    },
    "dimensions": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/dimension" }
    },
    "overall_recommendation": {
      "type": "object",
      "required": ["mode", "description"],
      "additionalProperties": true,
      "properties": {
        "mode": { "type": "string", "enum": ["partner_only"] },
        "description": { "type": "string" },
        "conventional_options": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  },
  "definitions": {
    "dimension": {
      "type": "object",
      "required": ["id", "name", "mode", "description"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$",
          "description": "Stable ID — referenced by qa_library.yaml. Do not rename without updating cross-references."
        },
        "name": { "type": "string", "minLength": 1 },
        "mode": { "type": "string", "enum": ["machine", "partner_only", "hybrid"] },
        "description": { "type": "string", "minLength": 1 },
        "sources": {
          "type": "array",
          "items": { "type": "string" }
        },
        "criteria": {
          "type": "object",
          "patternProperties": {
            "^[0-9]+$": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": false
        },
        "signals_to_consider": {
          "type": "array",
          "items": { "type": "string" }
        },
        "flag_low_confidence_when": {
          "type": "array",
          "items": { "type": "string" }
        },
        "informed_by_qa_categories": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Required only when mode = partner_only. Cross-reference to qa_library.yaml category IDs."
        },
        "agent_behavior": {
          "type": "string",
          "description": "Inline behavioral instruction. Required for partner_only dimensions."
        }
      },
      "allOf": [
        {
          "if": { "properties": { "mode": { "const": "partner_only" } } },
          "then": {
            "required": ["agent_behavior"],
            "description": "partner_only dimensions must specify agent_behavior so the agent knows not to score."
          }
        },
        {
          "if": { "properties": { "mode": { "const": "machine" } } },
          "then": {
            "required": ["criteria"],
            "description": "machine-scored dimensions must define scoring criteria for each level."
          }
        }
      ]
    }
  }
}
