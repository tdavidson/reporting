{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://memo-agent.local/schemas/memo_output.schema.json",
  "title": "Memo Agent Memo Output",
  "description": "Memo assembly format with paragraph-level provenance, partner-only fields, and draft-only enforcement.",
  "type": "object",
  "required": [
    "memo_structure",
    "paragraph_record",
    "source_reference",
    "score_block",
    "partner_attention",
    "citation_map",
    "memo_draft_output",
    "hard_rules"
  ],
  "additionalProperties": false,
  "properties": {
    "meta": { "type": "object", "additionalProperties": true },
    "memo_structure": {
      "type": "object",
      "required": ["sections"],
      "additionalProperties": true,
      "properties": {
        "description": { "type": "string" },
        "sections": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/section" }
        }
      }
    },
    "paragraph_record": { "$ref": "#/definitions/record_with_fields" },
    "source_reference": { "$ref": "#/definitions/record_with_fields" },
    "score_block": { "$ref": "#/definitions/record_with_fields" },
    "partner_attention": {
      "type": "object",
      "required": ["item_record"],
      "additionalProperties": true,
      "properties": {
        "description": { "type": "string" },
        "item_record": { "$ref": "#/definitions/record_with_fields" }
      }
    },
    "citation_map": {
      "type": "object",
      "required": ["entry_record"],
      "additionalProperties": true,
      "properties": {
        "description": { "type": "string" },
        "entry_record": { "$ref": "#/definitions/record_with_fields" }
      }
    },
    "memo_draft_output": { "$ref": "#/definitions/record_with_fields" },
    "hard_rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "rule"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^r_[0-9]{3}$" },
          "rule": { "type": "string", "minLength": 1 }
        }
      }
    }
  },
  "definitions": {
    "section": {
      "type": "object",
      "required": ["id", "title", "kind"],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "title": { "type": "string", "minLength": 1 },
        "kind": { "type": "string", "enum": ["metadata", "prose", "partner_only", "hybrid", "structured"] },
        "max_paragraphs": { "type": "integer", "minimum": 1 },
        "fields": { "type": "array", "items": { "type": "string" } },
        "partner_only_fields": { "type": "array", "items": { "type": "string" } },
        "machine_fields": { "type": "array", "items": { "type": "string" } },
        "sources": { "type": "array", "items": { "type": "string" } },
        "feeds_score": { "type": "string" },
        "guidance": { "type": "string" },
        "agent_behavior": { "type": "string" },
        "content": { "type": "string" }
      }
    },
    "record_with_fields": {
      "type": "object",
      "required": ["fields"],
      "additionalProperties": true,
      "properties": {
        "description": { "type": "string" },
        "fields": { "type": "array", "minItems": 1, "items": { "$ref": "#/definitions/field_spec" } }
      }
    },
    "field_spec": {
      "type": "object",
      "required": ["name", "type"],
      "additionalProperties": true,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "type": { "type": "string" },
        "required": { "type": "boolean" },
        "values": { "type": "array" },
        "default": {},
        "note": { "type": "string" }
      }
    }
  }
}
