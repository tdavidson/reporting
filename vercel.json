{
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/vc-market/cron",
      "schedule": "0 13 * * *"
    }
  ],
  "functions": {
    "app/api/inbound-email/route.ts": {
      "maxDuration": 120
    },
    "app/api/companies/*/summary/route.ts": {
      "maxDuration": 30
    },
    "app/api/emails/*/reprocess/route.ts": {
      "maxDuration": 120
    },
    "app/api/vc-market/cron/route.ts": {
      "maxDuration": 120
    }
  }
}
